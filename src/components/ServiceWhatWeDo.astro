---
interface Props {
    title?: string;
    body: string | string[];
    ctaLabel?: string;
    ctaHref?: string;
}

const {
    title = "Wat gaan we doen",
    body,
    ctaLabel = "Stuur een bericht met je vragen",
    ctaHref = "#",
} = Astro.props as Props;

const parts = Array.isArray(body)
    ? body
    : body
          .split(/\n{2,}/)
          .map((part) => part.trim())
          .filter(Boolean);
---

<section class="rounded-2xl border border-secondary/20 bg-white p-6 shadow-sm md:p-8">
    <h2 class="text-2xl font-bold text-secondary md:text-3xl">{title}</h2>
    <div class="mt-4 space-y-3 text-text">
        {
            parts.map((part) => (
                <p>{part}</p>
            ))
        }
    </div>
    <a
        href={ctaHref}
        class="mt-6 inline-flex items-center rounded-full bg-secondary px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-secondary-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-main"
    >
        {ctaLabel}
    </a>
</section>
