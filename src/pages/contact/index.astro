---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import ContactForm from "../../components/ContactForm.astro";
import { page } from "../../data/contact";
import { ui } from "../../data/ui";
import { getLangFromUrl, localize } from "../../i18n";

const lang = getLangFromUrl(Astro.url);
const params = Astro.url.searchParams;
const sent = params.get("sent");
const reason = params.get("reason");
const initialValues = {
    name: params.get("name") ?? "",
    city: params.get("city") ?? "",
    phone: params.get("phone") ?? "",
    email: params.get("email") ?? "",
    interest: params.get("interest") ?? "",
    message: params.get("message") ?? "",
    information_consent:
        params.get("information_consent") === "yes" ? "yes" : "",
};

const failureMessages = {
    rate_limited: localize(ui.contactForm.errorRateLimited, lang),
    token_invalid: localize(ui.contactForm.errorSessionExpired, lang),
    token_missing: localize(ui.contactForm.errorSessionExpired, lang),
    token_unavailable: localize(ui.contactForm.errorSessionExpired, lang),
    timing_invalid: localize(ui.contactForm.errorSessionExpired, lang),
    consent_missing: localize(ui.contactForm.errorConsentRequired, lang),
    required_invalid: localize(ui.contactForm.errorCheckFields, lang),
    name_invalid: localize(ui.contactForm.errorCheckFields, lang),
    email_invalid: localize(ui.contactForm.errorEmail, lang),
    message_invalid: localize(ui.contactForm.errorMessageShort, lang),
    field_quality_invalid: localize(ui.contactForm.errorCheckFields, lang),
    content_type_invalid: localize(ui.contactForm.errorGeneric, lang),
    spam_detected: localize(ui.contactForm.errorGeneric, lang),
    mail_unavailable: localize(ui.contactForm.errorSubmit, lang),
    mail_send_failed: localize(ui.contactForm.errorSubmit, lang),
} as const;

const initialStatus =
    sent === "1"
        ? {
              type: "success" as const,
              message: localize(ui.contactForm.success, lang),
          }
        : sent === "0"
          ? {
                type: "error" as const,
                message:
                    failureMessages[
                        (reason as keyof typeof failureMessages) ??
                            "token_invalid"
                    ] ?? localize(ui.contactForm.errorGeneric, lang),
            }
          : undefined;
---

<BaseLayout
    title={localize(page.seo.title, lang)}
    description={localize(page.seo.description, lang)}
>
    <Hero
        title={localize(page.hero.title, lang)}
        subtitle={localize(page.hero.lead, lang)}
        imageSrc={page.hero.image}
        imageAlt={localize(page.hero.imageAlt, lang)}
        titleKey="contact.page.hero.title"
        subtitleKey="contact.page.hero.lead"
        imageAltKey="contact.page.hero.imageAlt"
    />

    <section class="section">
        <div class="container grid gap-6 lg:grid-cols-[1.55fr,1fr]">
            <article
                class="rounded-2xl border border-secondary/25 bg-white p-6 shadow-sm"
            >
                <h2
                    class="text-3xl font-bold tracking-tight text-secondary md:text-4xl"
                >
                    <span data-i18n="contact.page.formSectionTitle"
                        >{localize(page.formSectionTitle, lang)}</span
                    >
                </h2>
                <ContactForm
                    lang={lang}
                    interestGroups={page.contactForm.interestGroups}
                    initialValues={initialValues}
                    initialStatus={initialStatus}
                />
            </article>

            <aside
                class="rounded-2xl border border-main/35 bg-main-soft p-6 shadow-sm"
            >
                <h2
                    class="text-3xl font-bold tracking-tight text-secondary md:text-4xl"
                >
                    <span data-i18n="contact.page.directSectionTitle"
                        >{localize(page.directSectionTitle, lang)}</span
                    >
                </h2>
                <p>
                    <strong data-i18n="contact.page.contactDetails.phoneLabel"
                        >{
                            localize(page.contactDetails.phoneLabel, lang)
                        }</strong
                    >:
                    <a
                        href={localize(page.contactDetails.phoneHref, lang)}
                        data-i18n-attr="href:contact.page.contactDetails.phoneHref"
                    >
                        <span data-i18n="contact.page.contactDetails.phone">
                            {localize(page.contactDetails.phone, lang)}
                        </span>
                    </a>
                </p>
                <p>
                    <strong data-i18n="contact.page.contactDetails.emailLabel"
                        >{
                            localize(page.contactDetails.emailLabel, lang)
                        }</strong
                    >:
                    <a
                        href={localize(page.contactDetails.emailHref, lang)}
                        data-i18n-attr="href:contact.page.contactDetails.emailHref"
                    >
                        <span data-i18n="contact.page.contactDetails.email">
                            {localize(page.contactDetails.email, lang)}
                        </span>
                    </a>
                </p>
                <p>
                    <strong
                        data-i18n="contact.page.contactDetails.serviceAreaLabel"
                        >{
                            localize(page.contactDetails.serviceAreaLabel, lang)
                        }</strong
                    >:
                    <span data-i18n="contact.page.contactDetails.serviceArea">
                        {localize(page.contactDetails.serviceArea, lang)}
                    </span>
                </p>
                <p>
                    <strong data-i18n="contact.page.contactDetails.kvkLabel"
                        >{localize(page.contactDetails.kvkLabel, lang)}</strong
                    >:
                    <span data-i18n="contact.page.contactDetails.kvk">
                        {localize(page.contactDetails.kvk, lang)}
                    </span>
                </p>
                <hr class="my-4 border-main/35" />
                <p class="m-0 text-sm text-text">
                    <span data-i18n="contact.page.bookingHelp"
                        >{localize(page.bookingHelp, lang)}</span
                    >
                </p>
                <div class="btn-row mt-4">
                    <a
                        class="btn btn-primary"
                        href={page.bookingCta.href}
                        target="_blank"
                        rel="noreferrer"
                        data-i18n="contact.page.bookingCta.label"
                        >{localize(page.bookingCta.label, lang)}</a
                    >
                </div>
            </aside>
        </div>
    </section>
</BaseLayout>
