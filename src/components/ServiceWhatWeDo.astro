---
interface Props {
    title?: string;
    titleKey?: string;
    body: string | string[];
    bodyKeys?: string[];
    ctaLabel?: string;
    ctaLabelKey?: string;
    ctaHref?: string;
}

const {
    title = "",
    titleKey,
    body,
    bodyKeys = [],
    ctaLabel = "",
    ctaLabelKey,
    ctaHref = "#",
} = Astro.props as Props;

const parts = Array.isArray(body)
    ? body
    : body
          .split(/\n{2,}/)
          .map((part) => part.trim())
          .filter(Boolean);
---

<section
    class="rounded-2xl border border-secondary/20 bg-white p-6 shadow-sm md:p-8"
>
    <h2 class="text-2xl font-bold text-secondary md:text-3xl">
        {titleKey ? <span data-i18n={titleKey}>{title}</span> : title}
    </h2>
    <div class="mt-4 space-y-3 text-text">
        {
            parts.map((part, index) => (
                <p>
                    {bodyKeys[index] ? (
                        <span data-i18n={bodyKeys[index]}>{part}</span>
                    ) : (
                        part
                    )}
                </p>
            ))
        }
    </div>
    <a
        href={ctaHref}
        class="mt-6 inline-flex items-center rounded-full bg-secondary px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-secondary-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-main"
    >
        {
            ctaLabelKey ? (
                <span data-i18n={ctaLabelKey}>{ctaLabel}</span>
            ) : (
                ctaLabel
            )
        }
    </a>
</section>
