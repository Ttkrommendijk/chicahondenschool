---
import { localize, type Lang, type L10n } from "../i18n";
import { ui } from "../data/ui";

interface InterestGroup {
    label: L10n;
    options: readonly L10n[];
}

interface Props {
    lang: Lang;
    interestGroups: readonly InterestGroup[];
    initialValues?: Partial<
        Record<FormFieldName | "information_consent", string>
    >;
    initialStatus?: {
        type: "success" | "error";
        message: string;
    };
}

type FormFieldName =
    | "name"
    | "city"
    | "phone"
    | "email"
    | "interest"
    | "message";

const {
    lang,
    interestGroups,
    initialValues = {},
    initialStatus,
} = Astro.props as Props;

const text = {
    name: localize(ui.contactForm.name, lang),
    city: localize(ui.contactForm.city, lang),
    phone: localize(ui.contactForm.phone, lang),
    phoneHelp: localize(ui.contactForm.phoneHelp, lang),
    email: localize(ui.contactForm.email, lang),
    interest: localize(ui.contactForm.interest, lang),
    interestPlaceholder: localize(ui.contactForm.interestPlaceholder, lang),
    message: localize(ui.contactForm.message, lang),
    messagePlaceholder: localize(ui.contactForm.messagePlaceholder, lang),
    consentLabel: localize(ui.contactForm.consentLabel, lang),
    submit: localize(ui.contactForm.submit, lang),
    submitting: localize(ui.contactForm.submitting, lang),
    errorRequired: localize(ui.contactForm.errorRequired, lang),
    errorEmail: localize(ui.contactForm.errorEmail, lang),
    errorMessageShort: localize(ui.contactForm.errorMessageShort, lang),
    errorCheckFields: localize(ui.contactForm.errorCheckFields, lang),
    errorSubmit: localize(ui.contactForm.errorSubmit, lang),
    success: localize(ui.contactForm.success, lang),
    errorGeneric: localize(ui.contactForm.errorGeneric, lang),
    errorConsentRequired: localize(ui.contactForm.errorConsentRequired, lang),
    errorSessionExpired: localize(ui.contactForm.errorSessionExpired, lang),
    errorRateLimited: localize(ui.contactForm.errorRateLimited, lang),
    errorVerificationRequired: localize(
        ui.contactForm.errorVerificationRequired,
        lang,
    ),
    errorVerificationUnavailable: localize(
        ui.contactForm.errorVerificationUnavailable,
        lang,
    ),
};

const minimumFillTimeMs = 3000;
const formSecurityEndpoint = "/contact-form-session.php";
const values = {
    name: initialValues.name ?? "",
    city: initialValues.city ?? "",
    phone: initialValues.phone ?? "",
    email: initialValues.email ?? "",
    interest: initialValues.interest ?? "",
    message: initialValues.message ?? "",
};
---

<form
    class="contact-form"
    action="/contact-submit.php"
    method="post"
    data-contact-form
    data-form-locked="true"
    data-min-fill-ms={minimumFillTimeMs}
    data-security-endpoint={formSecurityEndpoint}
    novalidate
>
    {
        initialStatus && (
            <p
                class:list={[
                    "m-0 mb-4 text-sm",
                    initialStatus.type === "success"
                        ? "text-detail"
                        : "text-secondary",
                ]}
                data-server-status
            >
                {initialStatus.message}
            </p>
        )
    }

    <input type="hidden" name="form_started_at" value="" data-form-started-at />
    <input type="hidden" name="form_token" value="" data-form-token />
    <input type="hidden" name="return_to" value={`/contact/?lang=${lang}`} />

    <div class="contact-form-grid">
        <div>
            <label for="name" data-i18n="ui.contactForm.name">{text.name}</label
            >
            <input
                id="name"
                name="name"
                type="text"
                autocomplete="name"
                value={values.name}
                required
            />
            <p class="field-error" data-error-for="name"></p>
        </div>

        <div>
            <label for="city" data-i18n="ui.contactForm.city">{text.city}</label
            >
            <input
                id="city"
                name="city"
                type="text"
                autocomplete="address-level2"
                value={values.city}
                required
            />
            <p class="field-error" data-error-for="city"></p>
        </div>

        <div>
            <label for="phone" data-i18n="ui.contactForm.phone"
                >{text.phone}</label
            >
            <input
                id="phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                value={values.phone}
                required
            />
            <p class="field-help" data-i18n="ui.contactForm.phoneHelp">
                {text.phoneHelp}
            </p>
            <p class="field-error" data-error-for="phone"></p>
        </div>

        <div>
            <label for="email" data-i18n="ui.contactForm.email"
                >{text.email}</label
            >
            <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                value={values.email}
                required
            />
            <p class="field-error" data-error-for="email"></p>
        </div>
    </div>

    <div class="mt-4">
        <label for="interest" data-i18n="ui.contactForm.interest"
            >{text.interest}</label
        >
        <select id="interest" name="interest" required>
            <option value="" data-i18n="ui.contactForm.interestPlaceholder"
                >{text.interestPlaceholder}</option
            >
            {
                interestGroups.map((group, groupIndex) => (
                    <optgroup
                        label={localize(group.label, lang)}
                        data-i18n-attr={`label:contact.page.contactForm.interestGroups.${groupIndex}.label`}
                    >
                        {group.options.map((option, optionIndex) => (
                            <option
                                value={localize(option, lang)}
                                selected={
                                    values.interest === localize(option, lang)
                                }
                                data-i18n={`contact.page.contactForm.interestGroups.${groupIndex}.options.${optionIndex}`}
                            >
                                {localize(option, lang)}
                            </option>
                        ))}
                    </optgroup>
                ))
            }
        </select>
        <p class="field-error" data-error-for="interest"></p>
    </div>

    <div class="mt-4">
        <label for="message" data-i18n="ui.contactForm.message"
            >{text.message}</label
        >
        <textarea
            id="message"
            name="message"
            rows="5"
            data-i18n-attr="placeholder:ui.contactForm.messagePlaceholder"
            placeholder={text.messagePlaceholder}
            required>{values.message}</textarea
        >
        <p class="field-error" data-error-for="message"></p>
    </div>

    <div class="mt-4">
        <div class="consent-row">
            <input
                id="information-consent"
                name="information_consent"
                type="checkbox"
                value="yes"
                checked={initialValues.information_consent === "yes"}
            />
            <label
                for="information-consent"
                data-i18n="ui.contactForm.consentLabel"
                >{text.consentLabel}</label
            >
        </div>
    </div>

    <div class="hidden-field" aria-hidden="true">
        <input
            type="text"
            name="company"
            tabindex="-1"
            autocomplete="off"
            value=""
        />
    </div>

    <div class="mt-5 flex flex-wrap items-center gap-3">
        <div class="turnstile-slot" data-turnstile-slot></div>
        <button
            class="btn btn-primary"
            type="submit"
            data-submit-button
            data-i18n="ui.contactForm.submit"
            data-i18n-attr="data-label-default:ui.contactForm.submit;data-label-loading:ui.contactForm.submitting"
            data-label-default={text.submit}
            data-label-loading={text.submitting}>{text.submit}</button
        >
        <p
            class="m-0 text-sm"
            data-form-status
            data-i18n-attr="data-error-required:ui.contactForm.errorRequired;data-error-email:ui.contactForm.errorEmail;data-error-message-short:ui.contactForm.errorMessageShort;data-error-check-fields:ui.contactForm.errorCheckFields;data-error-submit:ui.contactForm.errorSubmit;data-success:ui.contactForm.success;data-error-generic:ui.contactForm.errorGeneric;data-error-consent-required:ui.contactForm.errorConsentRequired;data-error-session-expired:ui.contactForm.errorSessionExpired;data-error-rate-limited:ui.contactForm.errorRateLimited;data-error-verification-required:ui.contactForm.errorVerificationRequired;data-error-verification-unavailable:ui.contactForm.errorVerificationUnavailable"
            data-error-required={text.errorRequired}
            data-error-email={text.errorEmail}
            data-error-message-short={text.errorMessageShort}
            data-error-check-fields={text.errorCheckFields}
            data-error-submit={text.errorSubmit}
            data-success={text.success}
            data-error-generic={text.errorGeneric}
            data-error-consent-required={text.errorConsentRequired}
            data-error-session-expired={text.errorSessionExpired}
            data-error-rate-limited={text.errorRateLimited}
            data-error-verification-required={text.errorVerificationRequired}
            data-error-verification-unavailable={text.errorVerificationUnavailable}
            aria-live="polite"
        >
        </p>
    </div>
</form>

<script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit"
    async
    defer></script>

<script>
    type FormFields = Record<FormFieldName, string>;
    type FieldControl =
        | HTMLInputElement
        | HTMLTextAreaElement
        | HTMLSelectElement;
    type SecurityResponse = {
        token?: string;
        message?: string;
        turnstileSiteKey?: string;
    };
    type SubmitResponse = { message?: string };
    type TurnstileRenderOptions = {
        sitekey: string;
        callback?: (token: string) => void;
        "expired-callback"?: () => void;
        "error-callback"?: () => void;
    };
    type TurnstileApi = {
        render: (
            container: HTMLElement | string,
            options: TurnstileRenderOptions,
        ) => string;
        reset: (widgetId?: string) => void;
    };
    type WindowWithTurnstile = Window & {
        turnstile?: TurnstileApi;
    };

    const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
    if (!form) {
        // Keep top-level valid for module script output.
    } else {
        const status = form.querySelector<HTMLElement>("[data-form-status]");
        const submitButton = form.querySelector<HTMLButtonElement>(
            "[data-submit-button]",
        );
        const consentCheckbox = form.querySelector<HTMLInputElement>(
            "#information-consent",
        );
        const minimumFillTimeMs = Number(
            form.getAttribute("data-min-fill-ms") ?? "3000",
        );
        const securityEndpoint =
            form.getAttribute("data-security-endpoint") ??
            "/contact-form-session.php";
        const startedAtInput = form.querySelector<HTMLInputElement>(
            "[data-form-started-at]",
        );
        const tokenInput =
            form.querySelector<HTMLInputElement>("[data-form-token]");
        const turnstileSlot = form.querySelector<HTMLElement>(
            "[data-turnstile-slot]",
        );
        let securityReady = false;
        let turnstileReady = false;
        let turnstileWidgetId: string | null = null;

        let labels = {
            default: "",
            loading: "",
            required: "",
            email: "",
            messageShort: "",
            checkFields: "",
            submit: "",
            success: "",
            generic: "",
            consentRequired: "",
            sessionExpired: "",
            rateLimited: "",
            verificationRequired: "",
            verificationUnavailable: "",
        };

        const syncLabels = (): void => {
            labels = {
                default: submitButton?.getAttribute("data-label-default") ?? "",
                loading: submitButton?.getAttribute("data-label-loading") ?? "",
                required: status?.getAttribute("data-error-required") ?? "",
                email: status?.getAttribute("data-error-email") ?? "",
                messageShort:
                    status?.getAttribute("data-error-message-short") ?? "",
                checkFields:
                    status?.getAttribute("data-error-check-fields") ?? "",
                submit: status?.getAttribute("data-error-submit") ?? "",
                success: status?.getAttribute("data-success") ?? "",
                generic: status?.getAttribute("data-error-generic") ?? "",
                consentRequired:
                    status?.getAttribute("data-error-consent-required") ?? "",
                sessionExpired:
                    status?.getAttribute("data-error-session-expired") ?? "",
                rateLimited:
                    status?.getAttribute("data-error-rate-limited") ?? "",
                verificationRequired:
                    status?.getAttribute("data-error-verification-required") ??
                    "",
                verificationUnavailable:
                    status?.getAttribute(
                        "data-error-verification-unavailable",
                    ) ?? "",
            };
        };

        const requiredFields: FormFieldName[] = [
            "name",
            "city",
            "phone",
            "email",
            "interest",
            "message",
        ];

        const getField = (
            currentForm: HTMLFormElement,
            name: FormFieldName,
        ): FieldControl | null => {
            const el = currentForm.elements.namedItem(name);
            if (
                el instanceof HTMLInputElement ||
                el instanceof HTMLTextAreaElement ||
                el instanceof HTMLSelectElement
            ) {
                return el;
            }
            return null;
        };
        const setError = (fieldName: FormFieldName, message: string): void => {
            const field = getField(form, fieldName);
            const errorNode = form.querySelector<HTMLElement>(
                `[data-error-for="${fieldName}"]`,
            );

            if (field) {
                field.classList.toggle("has-error", Boolean(message));
                field.setAttribute("aria-invalid", message ? "true" : "false");
            }
            if (errorNode) {
                errorNode.textContent = message;
            }
        };

        const syncFormLocked = (): void => {
            const locked =
                !securityReady ||
                !turnstileReady ||
                !(consentCheckbox?.checked ?? false);
            form.dataset.formLocked = locked ? "true" : "false";
            if (submitButton) {
                submitButton.disabled = locked;
            }
        };

        const setStatusMessage = (
            message: string,
            className: "text-secondary" | "text-detail",
        ): void => {
            if (!status) return;
            status.textContent = message;
            status.className = "m-0 text-sm";
            status.classList.add(className);
        };

        const readJsonResponse = async <T extends { message?: string }>(
            response: Response,
            fallbackMessage: string,
        ): Promise<T> => {
            const raw = await response.text();

            try {
                return JSON.parse(raw) as T;
            } catch {
                throw new Error(
                    raw.trimStart().startsWith("<?php")
                        ? labels.sessionExpired
                        : fallbackMessage,
                );
            }
        };

        const waitForTurnstileApi = async (): Promise<TurnstileApi> => {
            const deadline = Date.now() + 10000;

            while (Date.now() < deadline) {
                const api = (window as WindowWithTurnstile).turnstile;
                if (api) {
                    return api;
                }

                await new Promise((resolve) => window.setTimeout(resolve, 100));
            }

            throw new Error(labels.verificationUnavailable);
        };

        const mountTurnstile = async (siteKey: string): Promise<void> => {
            if (!turnstileSlot) {
                throw new Error(labels.verificationUnavailable);
            }

            const api = await waitForTurnstileApi();

            if (turnstileWidgetId) {
                turnstileReady = false;
                api.reset(turnstileWidgetId);
                syncFormLocked();
                return;
            }

            turnstileWidgetId = api.render(turnstileSlot, {
                sitekey: siteKey,
                callback: (token: string) => {
                    turnstileReady = token.trim().length > 0;
                    syncFormLocked();
                },
                "expired-callback": () => {
                    turnstileReady = false;
                    syncFormLocked();
                    setStatusMessage(
                        labels.verificationRequired,
                        "text-secondary",
                    );
                },
                "error-callback": () => {
                    turnstileReady = false;
                    syncFormLocked();
                    setStatusMessage(
                        labels.verificationUnavailable,
                        "text-secondary",
                    );
                },
            });
        };

        const resetTurnstile = (): void => {
            turnstileReady = false;
            const api = (window as WindowWithTurnstile).turnstile;
            if (api && turnstileWidgetId) {
                api.reset(turnstileWidgetId);
            }
            syncFormLocked();
        };

        const refreshSecurityFields = async (): Promise<void> => {
            securityReady = false;
            turnstileReady = false;
            syncFormLocked();

            try {
                const response = await fetch(securityEndpoint, {
                    headers: {
                        Accept: "application/json",
                        "X-Requested-With": "XMLHttpRequest",
                    },
                    credentials: "same-origin",
                    cache: "no-store",
                });
                const data = await readJsonResponse<SecurityResponse>(
                    response,
                    labels.sessionExpired,
                );

                if (
                    !response.ok ||
                    !data.token ||
                    !data.turnstileSiteKey ||
                    !tokenInput ||
                    !startedAtInput
                ) {
                    throw new Error(
                        data.message ?? labels.verificationUnavailable,
                    );
                }

                tokenInput.value = data.token;
                startedAtInput.value = Math.floor(Date.now() / 1000).toString();
                securityReady = true;
                await mountTurnstile(data.turnstileSiteKey);
            } catch (error: unknown) {
                securityReady = false;
                turnstileReady = false;
                setStatusMessage(
                    error instanceof Error && error.message
                        ? error.message
                        : labels.verificationUnavailable,
                    "text-secondary",
                );
            } finally {
                syncFormLocked();
            }
        };

        syncLabels();
        syncFormLocked();
        consentCheckbox?.addEventListener("change", () => {
            syncFormLocked();
        });
        window.addEventListener("app:langchange", () => {
            syncLabels();
            if (submitButton && !submitButton.disabled) {
                submitButton.textContent = labels.default;
            }
        });

        const clearState = (): void => {
            requiredFields.forEach((fieldName: FormFieldName) => {
                setError(fieldName, "");
            });
            if (status) {
                status.textContent = "";
                status.className = "m-0 text-sm";
            }
        };

        const isEmail = (value: string): boolean => {
            const emailField = getField(form, "email");
            if (!(emailField instanceof HTMLInputElement)) {
                return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value);
            }

            emailField.value = value;
            return (
                emailField.checkValidity() &&
                /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(value)
            );
        };

        form.addEventListener("submit", async (event: SubmitEvent) => {
            event.preventDefault();
            clearState();

            if (!consentCheckbox?.checked) {
                setStatusMessage(labels.consentRequired, "text-secondary");
                return;
            }

            const formData = new FormData(form);
            const payload: FormFields = {
                name: String(formData.get("name") ?? "").trim(),
                city: String(formData.get("city") ?? "").trim(),
                phone: String(formData.get("phone") ?? "").trim(),
                email: String(formData.get("email") ?? "").trim(),
                interest: String(formData.get("interest") ?? "").trim(),
                message: String(formData.get("message") ?? "").trim(),
            };
            const honeypotValue = String(formData.get("company") ?? "").trim();
            const startedAtSeconds = Number(
                formData.get("form_started_at") ?? "0",
            );
            const submittedTooFast =
                Date.now() - startedAtSeconds * 1000 < minimumFillTimeMs;

            if (
                !securityReady ||
                !turnstileReady ||
                !String(formData.get("form_token") ?? "").trim() ||
                !startedAtSeconds
            ) {
                setStatusMessage(
                    !turnstileReady
                        ? labels.verificationRequired
                        : labels.sessionExpired,
                    "text-secondary",
                );
                return;
            }

            if (honeypotValue || submittedTooFast) {
                setStatusMessage(labels.generic, "text-secondary");
                return;
            }

            let hasError = false;
            let hasEmailError = false;
            requiredFields.forEach((fieldName: FormFieldName) => {
                if (!payload[fieldName]) {
                    setError(fieldName, labels.required);
                    hasError = true;
                }
            });

            if (payload.email && !isEmail(payload.email)) {
                setError("email", labels.email);
                hasError = true;
                hasEmailError = true;
            }

            if (payload.message && payload.message.length < 10) {
                setError("message", labels.messageShort);
                hasError = true;
            }

            if (hasError) {
                setStatusMessage(
                    hasEmailError ? labels.email : labels.checkFields,
                    "text-detail",
                );
                return;
            }

            if (submitButton) {
                submitButton.disabled = true;
                submitButton.textContent = labels.loading;
            }

            try {
                const response = await fetch(
                    form.getAttribute("action") ?? "/contact-submit.php",
                    {
                        method: "POST",
                        body: formData,
                        headers: {
                            Accept: "application/json",
                            "X-Requested-With": "XMLHttpRequest",
                        },
                        credentials: "same-origin",
                    },
                );

                const data = await readJsonResponse<SubmitResponse>(
                    response,
                    labels.submit,
                );

                if (!response.ok) {
                    throw new Error(data.message ?? labels.submit);
                }

                form.reset();
                setStatusMessage(labels.success, "text-detail");
                resetTurnstile();
                await refreshSecurityFields();
            } catch (error: unknown) {
                setStatusMessage(
                    error instanceof Error ? error.message : labels.generic,
                    "text-secondary",
                );
                resetTurnstile();
                await refreshSecurityFields();
            } finally {
                if (submitButton) {
                    submitButton.textContent = labels.default;
                }
                syncFormLocked();
            }
        });

        void refreshSecurityFields();
    }
</script>

<style>
    .contact-form label {
        display: block;
        font-weight: 700;
        margin-bottom: 0.35rem;
        color: #5b5476;
    }

    .contact-form input,
    .contact-form select,
    .contact-form textarea {
        width: 100%;
        border: 1px solid #d8d3e5;
        border-radius: 10px;
        padding: 0.7rem 0.8rem;
        font: inherit;
        color: #1f1f29;
        background: #fff;
    }

    .contact-form input:focus-visible,
    .contact-form select:focus-visible,
    .contact-form textarea:focus-visible {
        outline: 2px solid #8accca;
        outline-offset: 2px;
    }

    .contact-form-grid {
        display: grid;
        gap: 1rem;
    }

    .consent-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .consent-row input[type="checkbox"] {
        width: 1.05rem;
        height: 1.05rem;
        margin-top: 0.2rem;
        padding: 0;
        flex: 0 0 auto;
    }

    .consent-row label {
        margin: 0;
        font-weight: 400;
        line-height: 1.5;
    }

    .hidden-field {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .field-help {
        margin: 0.35rem 0 0;
        color: #5b6165;
        font-size: 0.86rem;
    }

    .field-error {
        min-height: 1.05rem;
        margin: 0.3rem 0 0;
        color: #8f2d52;
        font-size: 0.83rem;
    }

    .turnstile-slot {
        min-height: 65px;
    }

    .contact-form .has-error {
        border-color: #8f2d52;
        background: #fff7fa;
    }

    .contact-form[data-form-locked="true"] .mt-5 {
        opacity: 0.48;
    }

    .contact-form[data-form-locked="true"] button[type="submit"] {
        cursor: not-allowed;
        background: #f5f2f8;
        color: #7e7990;
        box-shadow: none;
        pointer-events: none;
    }

    .contact-form[data-form-locked="true"] button[type="submit"]:hover {
        border-color: #d8d3e5;
        background: #f5f2f8;
        color: #7e7990;
        transform: none;
        box-shadow: none;
    }

    @media (min-width: 900px) {
        .contact-form-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>
